{
  "info": {
    "name": "AutomationStore API",
    "description": "REST API for the automation-store demo e-commerce app. Set {{base_url}} (default http://localhost:4002) and {{token}} (from Login/Register).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:4002" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/auth/register",
            "body": { "mode": "raw", "raw": "{\n  \"gender\": \"Male\",\n  \"name\": \"qatest\",\n  \"email\": \"qatest@example.com\",\n  \"password\": \"Passw0rd\",\n  \"birth_day\": \"5\",\n  \"birth_month\": \"5\",\n  \"birth_year\": \"2000\",\n  \"first_name\": \"Test\",\n  \"last_name\": \"User\",\n  \"address1\": \"123 Demo Street\",\n  \"country\": \"Thailand\",\n  \"state\": \"กรุงเทพมหานคร\",\n  \"city\": \"เขตห้วยขวาง\",\n  \"zipcode\": \"10310\",\n  \"mobile_number\": \"0912345678\"\n}" }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"Passw0rd\"\n}" }
          }
        },
        {
          "name": "Verify email exists",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/auth/verify",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"test@example.com\"\n}" }
          }
        },
        {
          "name": "Get my profile (me)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/auth/me"
          }
        },
        {
          "name": "Delete Account",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/auth/delete"
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        { "name": "List all", "request": { "method": "GET", "url": "{{base_url}}/api/products" } },
        { "name": "Search (dress)", "request": { "method": "GET", "url": "{{base_url}}/api/products?search=dress" } },
        { "name": "By category", "request": { "method": "GET", "url": "{{base_url}}/api/products?category=Women&subcategory=Tops" } },
        { "name": "By brand", "request": { "method": "GET", "url": "{{base_url}}/api/products?brand=Polo" } },
        { "name": "Detail", "request": { "method": "GET", "url": "{{base_url}}/api/products/1" } },
        { "name": "Brands", "request": { "method": "GET", "url": "{{base_url}}/api/brands" } },
        { "name": "Categories", "request": { "method": "GET", "url": "{{base_url}}/api/categories" } }
      ]
    },
    {
      "name": "Reviews",
      "item": [
        { "name": "List for product", "request": { "method": "GET", "url": "{{base_url}}/api/products/1/reviews" } },
        {
          "name": "Create review",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/products/1/reviews",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Jane\",\n  \"email\": \"jane@example.com\",\n  \"review\": \"Great product!\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Cart (auth)",
      "item": [
        { "name": "Get cart", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{base_url}}/api/cart" } },
        {
          "name": "Add item",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/cart",
            "body": { "mode": "raw", "raw": "{\n  \"product_id\": 1,\n  \"quantity\": 2\n}" }
          }
        },
        {
          "name": "Update quantity",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/cart",
            "body": { "mode": "raw", "raw": "{\n  \"product_id\": 1,\n  \"quantity\": 5\n}" }
          }
        },
        { "name": "Remove item", "request": { "method": "DELETE", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{base_url}}/api/cart?product_id=1" } }
      ]
    },
    {
      "name": "Orders (auth)",
      "item": [
        { "name": "List my orders", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{base_url}}/api/orders" } },
        { "name": "Get order by id", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{base_url}}/api/orders/1" } },
        {
          "name": "Place order",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/orders",
            "body": { "mode": "raw", "raw": "{\n  \"items\": [{ \"product_id\": 1, \"quantity\": 2 }],\n  \"address\": {\n    \"full_name\": \"Test User\",\n    \"email\": \"test@example.com\",\n    \"phone\": \"0812345678\",\n    \"address\": \"123 Demo St\",\n    \"city\": \"Mueang\",\n    \"state\": \"Bangkok\",\n    \"zipcode\": \"10110\",\n    \"country\": \"Thailand\"\n  },\n  \"shipping_method\": \"Ground\",\n  \"payment_method\": \"Credit Card\",\n  \"card\": { \"number\": \"4111111111111111\" }\n}" }
          }
        }
      ]
    },
    {
      "name": "Locations (Thailand)",
      "item": [
        { "name": "Provinces (จังหวัด)", "request": { "method": "GET", "url": "{{base_url}}/api/locations/provinces" } },
        { "name": "Districts (อำเภอ) by province", "request": { "method": "GET", "url": "{{base_url}}/api/locations/districts?province_id=1" } }
      ]
    },
    {
      "name": "Subscription",
      "item": [
        {
          "name": "Subscribe",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/subscription",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"news@example.com\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Contact",
      "item": [
        {
          "name": "Send message",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/contact",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Test\",\n  \"email\": \"test@example.com\",\n  \"subject\": \"Hello\",\n  \"message\": \"Nice store!\"\n}" }
          }
        }
      ]
    }
  ]
}
